{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["astro/client", "vitest/globals"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.astro",
    "tests/**/*.ts",
    "tooling/**/*.mjs",
    "tooling/**/*.ts",
    "*.mjs",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "dist", "references"]
}
