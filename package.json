{
  "name": "henrique-tavares",
  "private": true,
  "description": "Henrique Tavares",
  "version": "1.0.0",
  "author": "Henrique Tavares <ihenrits@gmail.com>",
  "dependencies": {},
  "devDependencies": {
    "@astrojs/tailwind": "^6.0.0",
    "@eslint/js": "^9.24.0",
    "@vitest/coverage-v8": "^3.0.0",
    "astro": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "globals": "^15.0.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.4.0",
    "postcss": "^8.4.0",
    "prettier": "^3.5.0",
    "prettier-plugin-astro": "^0.14.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.0.0",
    "yaml": "^2.8.0",
    "zod": "^3.25.76"
  },
  "homepage": "https://henriquetavares.com",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "dev": "astro dev",
    "preview": "astro preview",
    "build": "astro build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"{astro.config.*,tailwind.config.*,eslint.config.mjs,vitest.config.ts,src/**/*.{astro,ts,tsx,css,scss},src/**/*.json,tooling/**/*.{mjs,js,ts},tests/**/*.{ts,mjs}}\"",
    "format:check": "prettier --check \"{astro.config.*,tailwind.config.*,eslint.config.mjs,vitest.config.ts,src/**/*.{astro,ts,tsx,css,scss},src/**/*.json,tooling/**/*.{mjs,js,ts},tests/**/*.{ts,mjs}}\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit:migration": "tsx tooling/migration-audit.ts",
    "validate": "yarn lint && yarn build && yarn audit:migration"
  },
  "lint-staged": {
    "*.{astro,ts,tsx,mjs,cjs,json,css,scss}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
