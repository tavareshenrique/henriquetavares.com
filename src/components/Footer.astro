---
import type { Lang } from '../lib/routes';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer
  data-region="article-site-footer"
  class="mt-10 flex flex-row flex-wrap items-start justify-between gap-4 pt-6 font-serif text-[0.95rem]"
>
  <div class="flex flex-row flex-wrap gap-x-2 gap-y-1">
    <a
      href="https://github.com/tavareshenrique"
      target="_blank"
      rel="noopener noreferrer"
      class="text-blog-link no-underline shadow-none hover:underline"
    >
      github
    </a>
    <span class="text-blog-text opacity-70">&bull;</span>
    <a
      href="https://www.linkedin.com/in/tavareshenrique/"
      target="_blank"
      rel="noopener noreferrer"
      class="text-blog-link no-underline shadow-none hover:underline"
    >
      linkedin
    </a>
  </div>
  <div>
    <a href="mailto:ihenrits@gmail.com" rel="noopener noreferrer" class="text-blog-link no-underline hover:underline">
      {lang === 'pt-br' ? 'contato' : 'contact'}
    </a>
  </div>
</footer>
